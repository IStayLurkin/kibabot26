# ============================================================
# Kiba Bot — Environment Variable Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Discord ---
DISCORD_BOT_TOKEN=

# --- Bot Behaviour ---
BOT_PREFIX=!
BOT_TIMEZONE=America/Los_Angeles

# --- LLM ---
LLM_PROVIDER=ollama
LLM_TEMPERATURE=0.8
LLM_MAX_TOKENS=220
AGENTIC_CHAT_ENABLED=true
AGENTIC_CHAT_MAX_TOKENS=500

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=kiba
OLLAMA_CLI_PATH=
OLLAMA_REQUEST_TIMEOUT_SECONDS=180

# --- Hugging Face ---
HF_TOKEN=
HF_BASE_URL=https://router.huggingface.co/v1
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct:cerebras

# --- Feature Flags ---
IMAGE_ENABLED=true
VOICE_ENABLED=true
VIDEO_ENABLED=false
CODEGEN_ENABLED=true
AGENT_ENABLED=true
OSINT_ENABLED=true
SAFE_OSINT_ONLY=true

# --- Hardware ---
CUDA_PREFERRED=true
GPU_TOTAL_VRAM_MB=24576

# --- Media & Model Storage ---
MEDIA_OUTPUT_DIR=
MODEL_STORAGE_ROOT=
MODEL_PULL_TIMEOUT_SECONDS=1800
ENABLED_MODEL_PROVIDERS=openai,ollama,local,hf,automatic1111,comfyui
DEFAULT_MODEL_PROVIDER=ollama
PREFERRED_LOCAL_IMAGE_BACKEND=automatic1111

# --- Image Providers ---
IMAGE_PROVIDER=ollama
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_FORMAT=png

AUTOMATIC1111_BASE_URL=
AUTOMATIC1111_DEFAULT_MODEL=
AUTOMATIC1111_STEPS=28
AUTOMATIC1111_CFG_SCALE=7.0

COMFYUI_BASE_URL=
COMFYUI_DEFAULT_MODEL=
COMFYUI_STEPS=24
COMFYUI_CFG_SCALE=7.0
COMFYUI_SAMPLER_NAME=euler
COMFYUI_SCHEDULER=normal
COMFYUI_WIDTH=1024
COMFYUI_HEIGHT=1024

# --- Video ---
VIDEO_PROVIDER=ollama
OPENAI_VIDEO_MODEL=sora-2
OPENAI_VIDEO_SIZE=720x1280
OPENAI_VIDEO_SECONDS=4

# --- Voice / TTS ---
VOICE_PROVIDER=ollama
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# --- Music ---
MUSIC_PROVIDER=auto
MUSIC_STUDIO_API_URL=
MUSIC_STUDIO_API_KEY=
MUSIC_REQUEST_TIMEOUT_SECONDS=180
MUSIC_DEFAULT_QUALITY=studio

# --- Media Safety ---
MEDIA_SAFETY_MODE=none

# --- Gallery ---
GALLERY_CHANNEL_ID=

# --- Code Execution ---
CODE_WORKSPACE_ROOT=
CODE_SANDBOX_MODE=subprocess
CODE_EXECUTION_TIMEOUT_SECONDS=20
CODE_MAX_OUTPUT_CHARS=6000
CODE_ALLOWED_USER_IDS=
CODE_ALLOWED_ROLE_IDS=

# --- Limits ---
MAX_PROMPT_LENGTH=1800
MAX_TTS_LENGTH=1500
MAX_CODE_REQUEST_LENGTH=4000

# --- Agent ---
AGENT_DEFAULT_COOLDOWN_SECONDS=8
AGENT_MAX_CONTEXT_MESSAGES=15
