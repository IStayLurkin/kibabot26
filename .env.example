# Discord Configuration
DISCORD_TOKEN=your_token_here
BOT_PREFIX=!

# LLM / Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=kiba
AGENT_MAX_CONTEXT_MESSAGES=10

# Hardware / Path Configuration
# Use G: drive for local 3090 Ti setups
MEDIA_OUTPUT_DIR=G:/code/python/learn_python/bot/discord_bot_things/generated_media
MODEL_STORAGE_ROOT=G:/code/python/learn_python/bot/discord_bot_things/model_storage